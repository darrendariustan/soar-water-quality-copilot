# Copy this file to .env and fill in the real values. .env is gitignored.

# --- LLM (OpenAI) ---
# Used by the chat agent + education agent (text generation) AND by the
# knowledge ingestion/retrieval embeddings (OpenAIEmbeddings).
OPENAI_API_KEY=sk-your-openai-key
OPENAI_MODEL=gpt-4o-mini
# Leave OPENAI_BASE_URL unset to use the real OpenAI API.
# Set it only if pointing at an OpenAI-compatible server (e.g. LM Studio).
# OPENAI_BASE_URL=http://localhost:1234/v1

# --- Exa web crawl ---
EXA_API_KEY=your-exa-key

# --- Local PostgreSQL (pgvector) ---
# Matches the docker-compose db service (user/password/waterforall on 5432).
# Use localhost when the backend runs on your host machine.
DATABASE_URL=postgresql://user:password@localhost:5432/waterforall

# --- Frontend -> backend URL (browser side) ---
NEXT_PUBLIC_API_URL=http://localhost:8000

# --- AWS (optional) ---
# Only needed if you switch CV to "aws"/Bedrock mode. Local CV mode needs nothing.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_DEFAULT_REGION=us-east-1
